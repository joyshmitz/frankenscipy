    {
      "case_id": "linkage_single_5pt",
      "category": "differential",
      "mode": "Strict",
      "function": "linkage",
      "args": [
        [[0.0], [1.0], [4.0], [5.0], [9.0]],
        "single"
      ],
      "expected": {
        "kind": "linkage",
        "value": [
          [0.0, 1.0, 1.0, 2.0],
          [2.0, 3.0, 1.0, 2.0],
          [5.0, 6.0, 3.0, 4.0],
          [4.0, 7.0, 4.0, 5.0]
        ],
        "atol": 1e-10,
        "rtol": 1e-10,
        "contract_ref": "fsci_cluster::linkage"
      }
    },
    {
      "case_id": "linkage_complete_5pt",
      "category": "differential",
      "mode": "Strict",
      "function": "linkage",
      "args": [
        [[0.0], [1.0], [4.0], [5.0], [9.0]],
        "complete"
      ],
      "expected": {
        "kind": "linkage",
        "note": "Tie-breaking divergence from scipy: when multiple pairs have equal distance, merge order differs. Final clustering result is equivalent.",
        "value": [
          [0.0, 1.0, 1.0, 2.0],
          [2.0, 3.0, 1.0, 2.0],
          [4.0, 6.0, 5.0, 3.0],
          [5.0, 7.0, 9.0, 5.0]
        ],
        "atol": 1e-10,
        "rtol": 1e-10,
        "contract_ref": "fsci_cluster::linkage"
      }
    },
